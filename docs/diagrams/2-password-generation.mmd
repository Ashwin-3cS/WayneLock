flowchart LR
    subgraph Step1["Step 1: Device Entropy"]
        C["crypto.getRandomValues\n32 bytes"]
    end

    subgraph Step2["Step 2: drand Randomness"]
        R1["R1: Latest beacon round\n32 bytes verified"]
        R2["R2: Previous beacon round\n32 bytes verified"]
    end

    subgraph Step3["Step 3: HKDF"]
        HKDF1["HKDF-SHA256\ninput: R1 + C + local_raw_v1\nsalt: APP_SALT1"]
    end

    subgraph Step4["Step 4: Key Stretching"]
        SCRYPT1["scrypt\nN=16384 r=8 p=1\nLocalKey 32 bytes"]
    end

    subgraph Step5["Step 5: Seed Derivation"]
        HKDF2["HKDF-SHA256\ninput: LocalKey + R2 + seed_v1\nsalt: APP_SALT2"]
    end

    subgraph Step6["Step 6: Password Stretching"]
        SCRYPT2["scrypt\nN=16384 r=8 p=1\npassword_bytes 32 bytes"]
    end

    subgraph Step7["Step 7: Charset Mapping"]
        CHARSET["Map bytes to A-Z a-z 0-9 symbols\nFinal Password"]
    end

    C --> HKDF1
    R1 --> HKDF1
    HKDF1 --> SCRYPT1
    SCRYPT1 --> HKDF2
    R2 --> HKDF2
    HKDF2 --> SCRYPT2
    SCRYPT2 --> CHARSET
