{
    "manifest_version": 3,
    "name": "Decentralized Password Manager",
    "version": "1.0.0",
    "description": "A fully non-custodial, decentralized password manager using FWSS and FEVM",
    "background": {
        "service_worker": "src/background/index.ts",
        "type": "module"
    },
    "action": {
        "default_popup": "index.html"
    },
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://*.filecoin.cloud/*",
        "https://*.calibration.node.glif.io/*"
    ]
}